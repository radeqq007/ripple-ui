{
	"name": "ripple-ui",
	"version": "0.0.0",
	"description": "shadcn/ui inspired components library for Ripple TS",
	"type": "module",
	"scripts": {
		"build": "tsc",
		"lint": "biome check .",
		"format": "biome format . --write",
		"check": "biome check . --all",
		"publish": "npm publish"
	},
	"bin": {
		"ripple-ui": "dist/cli.js"
	},
	"keywords": [
		"ripple",
		"ui",
		"components"
	],
	"author": "Radosław Kaczmarczyk",
	"license": "MIT",
	"packageManager": "pnpm@10.32.1",
	"dependencies": {
		"commander": "^14.0.3",
		"fs-extra": "^11.3.4",
		"prompts": "^2.4.2"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@types/node": "^25.5.0",
		"@types/prompts": "^2.4.9",
		"clsx": "^2.1.1",
		"tailwind-merge": "^3.0.0",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2"
	},
	"peerDependencies": {
		"clsx": ">=2",
		"tailwind-merge": ">=3"
	}
}
