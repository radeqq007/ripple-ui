{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": {
    "type": "object",
    "required": ["files", "path"],
    "properties": {
      "files": {
        "type": "array",
        "items": { "type": "string" },
        "minItems": 1
      },
      "path": { "type": "string" },
      "dependencies": {
        "type": "array",
        "items": { "type": "string" }
      },
      "npmDependencies": {
        "type": "array",
        "items": { "type": "string" }
      },
      "target": { "type": "string" }
    },
    "additionalProperties": false
  }
}
